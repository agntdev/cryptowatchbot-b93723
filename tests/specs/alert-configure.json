[
  {
    "name": "Alert configuration flow - price above",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      },
      {
        "send": { "callback": "watchlist:add" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Type a ticker symbol (e.g. BTC, ETH, DOGE) or tap a common coin below:"
            }
          }
        ]
      },
      {
        "send": { "callback": "watchlist:quickadd:BTC" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Added Bitcoin (BTC) to your watchlist."
            }
          }
        ]
      },
      {
        "send": { "callback": "alert:configure:bitcoin" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Set alert for Bitcoin (BTC). What type of alert?"
            }
          }
        ]
      },
      {
        "send": { "callback": "alert:settype:bitcoin:price_above" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "What price should trigger the alert? (e.g. 50000 for $50,000)"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Alert configuration flow - percent change",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      },
      {
