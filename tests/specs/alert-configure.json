        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Type a ticker symbol (e.g. BTC, ETH, DOGE) or tap a common coin below:"
            }
          }
        ]
      },
      {
        "send": { "callback": "watchlist:quickadd:ETH" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "✅ Added Ethereum (ETH) to your watchlist."
            }
          }
        ]
      },
      {
        "send": { "callback": "alert:configure:ethereum" },
        "expect": [
