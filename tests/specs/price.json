[
  {
    "name": "Price check with no watchlist",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      },
      {
        "send": { "callback": "price:show" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No coins in your watchlist yet. Add some to track prices."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Price check with unknown ticker via /price",
    "steps": [
      {
        "send": { "text": "/price XYZCOIN" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Couldn't find \"XYZCOIN\". Check the symbol and try again."
            }
          }
        ]
      }
    ]
  }
]
