[
  {
    "name": "Morning summary with empty watchlist",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      },
      {
        "send": { "callback": "summary:send" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No coins in your watchlist yet. Add some to track prices."
            }
          }
        ]
      }
    ]
  }
]
