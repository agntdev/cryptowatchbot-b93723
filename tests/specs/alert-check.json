[
  {
    "name": "Alert check with no alerts",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      },
      {
        "send": { "callback": "alert:check" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "No active alerts. Set one up from your watchlist."
            }
          }
        ]
      }
    ]
  }
]
